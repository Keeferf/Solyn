{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "shell:allow-execute",
    "shell:allow-open",
    "shell:default",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "opener:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-unlisten"
  ]
}